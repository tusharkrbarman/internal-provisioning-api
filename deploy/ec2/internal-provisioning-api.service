[Unit]
Description=Internal Provisioning API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/internal-provisioning-api
EnvironmentFile=/etc/internal-provisioning-api.env
ExecStart=/opt/internal-provisioning-api/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
